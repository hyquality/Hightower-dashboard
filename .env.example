# --- Browser (Vite) — safe to expose in client bundle ---
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# Optional: override logo URL (otherwise app uses /hightower-logo-email.png on same origin)
# VITE_BRAND_LOGO_URL=https://your-cdn.com/hightower-logo.png

# Local dev: proxy /api/* to Vercel dev (default http://127.0.0.1:3000). Run `npx vercel dev` on 3000, or `vite` alone won't reach APIs.
# VITE_DEV_API_PROXY=http://127.0.0.1:3000

# --- Vercel serverless only (never VITE_*) ---
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

BREVO_API_KEY=
BREVO_SENDER_EMAIL=
# BREVO_SENDER_NAME=Hightower Funding

# Public site URL (no trailing slash) — used to build absolute <img src> for outbound emails:
#   {PUBLIC_APP_URL}/hightower-logo-email.png
# On Vercel, VERCEL_URL is usually enough; set this for a custom domain, e.g. https://dashboard.hightowerfunding.com
PUBLIC_APP_URL=

# Optional: full logo URL for outbound emails (overrides PUBLIC_APP_URL + /hightower-logo-email.png)
# BRAND_LOGO_URL=https://...

# Brevo → POST /api/webhooks/brevo must send this value as:
#   Header: x-webhook-secret: <value>   OR   Authorization: Bearer <value>
# If unset, the webhook is open (not recommended in production).
BREVO_WEBHOOK_SECRET=
